@model CustomerCreateViewModel

@{
    ViewData["Title"] = "Create Customer";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Create Customer</h1>
            <p class="text-muted mb-0">Chuyen giua Customer Company va Customer Person ngay tren cung mot form.</p>
        </div>
        <a asp-area="Customer" asp-controller="Customer" asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <form asp-area="Customer" asp-controller="Customer" asp-action="Create" method="post" novalidate>
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label class="form-label d-block">Customer Type</label>
                        <div class="btn-group" role="group" aria-label="Customer type">
                            <input type="radio" class="btn-check" name="RegistrationType" id="customerTypeCompany" value="Company" asp-for="RegistrationType" />
                            <label class="btn btn-outline-primary" for="customerTypeCompany">Company</label>

                            <input type="radio" class="btn-check" name="RegistrationType" id="customerTypePerson" value="Person" asp-for="RegistrationType" />
                            <label class="btn btn-outline-primary" for="customerTypePerson">Person</label>
                        </div>
                        <span asp-validation-for="RegistrationType" class="text-danger d-block mt-2"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="TaxId" class="form-label"></label>
                        <input asp-for="TaxId" class="form-control" />
                    </div>
                </div>

                <div class="row g-3" id="customerCompanySection">
                    <div class="col-12"><h2 class="h5">Company fields</h2></div>
                    <div class="col-md-6">
                        <label asp-for="CompanyName" class="form-label"></label>
                        <input asp-for="CompanyName" class="form-control" />
                    </div>

                </div>

                <div class="row g-3 mt-2" id="customerPersonSection">
                    <div class="col-12"><h2 class="h5">Person fields</h2></div>
                    <div class="col-md-6">
                        <label asp-for="FirstName" class="form-label"></label>
                        <input asp-for="FirstName" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="LastName" class="form-label"></label>
                        <input asp-for="LastName" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="DoB" class="form-label"></label>
                        <input asp-for="DoB" class="form-control" />
                    </div>
                </div>

                <div class="row g-3 mt-2">
                    <div class="col-12"><h2 class="h5">Contact and address</h2></div>
                    <div class="col-md-6">
                        <label asp-for="Phone" class="form-label"></label>
                        <input asp-for="Phone" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="AddressType" class="form-label"></label>
                        <input asp-for="AddressType" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Street" class="form-label"></label>
                        <input asp-for="Street" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="City" class="form-label"></label>
                        <input asp-for="City" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="State" class="form-label"></label>
                        <input asp-for="State" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Country" class="form-label"></label>
                        <input asp-for="Country" class="form-control" />
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save Customer</button>
                    <a asp-area="Customer" asp-controller="Customer" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const companyRadio = document.getElementById('customerTypeCompany');
            const personRadio = document.getElementById('customerTypePerson');
            const companySection = document.getElementById('customerCompanySection');
            const personSection = document.getElementById('customerPersonSection');

            function syncCustomerSections() {
                const isCompany = companyRadio.checked;
                companySection.style.display = isCompany ? '' : 'none';
                personSection.style.display = isCompany ? 'none' : '';
            }

            companyRadio.addEventListener('change', syncCustomerSections);
            personRadio.addEventListener('change', syncCustomerSections);
            syncCustomerSections();
        })();
    </script>
}
