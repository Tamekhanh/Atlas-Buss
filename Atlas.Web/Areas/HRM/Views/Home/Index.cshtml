@model IEnumerable<Employee>

@{
    ViewData["Title"] = "Employees";
}

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Employees</h1>
            <p class="text-muted mb-0">Danh sách nhân viên nối từ bảng Employee và Persons.</p>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded-3 bg-white">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Id</th>
                    <th>Employee Number</th>
                    <th>Full Name</th>
                    <th>Date of Birth</th>
                    <th>Address</th>
                    <th>Contact Id</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var employee in Model)
                    {
                        <tr>
                            <td>@employee.Id</td>
                            <td>@employee.EmployeeNumber</td>
                            <td>@employee.FullName</td>
                            <td>@employee.Person?.DoB.ToString("yyyy-MM-dd")</td>
                            <td>
                                @if (employee.Person?.Address != null)
                                {
                                    @($"{employee.Person.Address.Street}, {employee.Person.Address.City}, {employee.Person.Address.State}, {employee.Person.Address.Country}")
                                }
                                else
                                {
                                    @:N/A
                                }
                            </td>
                            <td>@employee.Person?.ContactId</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                            <td colspan="6" class="text-center py-5 text-muted">Chưa có dữ liệu nhân viên.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>