@model IEnumerable<ProductEntity>

@{
    ViewData["Title"] = "Products";
}

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Products</h1>
            <p class="text-muted mb-0">Danh sách sản phẩm lấy trực tiếp từ database.</p>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded-3 bg-white">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Id</th>
                    <th>Name</th>
                    <th>Code</th>
                    <th class="text-end">Sale Price</th>
                    <th class="text-end">Cost Price</th>
                    <th>Active</th>
                    <th>On Sale</th>
                    <th>Employee</th>
                    <th>Barcode</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var product in Model)
                    {
                        <tr class="clickable-row" tabindex="0" role="link" data-href="@Url.Action("Detail", "Product", new { area = "Products", id = product.Id })">
                            <td>@product.Id</td>
                            <td>
                                <a asp-area="Products"
                                   asp-controller="Product"
                                   asp-action="Detail"
                                   asp-route-id="@product.Id"
                                   class="fw-semibold text-decoration-none">
                                    @product.ProductName
                                </a>
                            </td>
                            <td>@product.ProductCode</td>
                            <td class="text-end">@product.SalePrice.ToString("N0")</td>
                            <td class="text-end">@product.CostPrice.ToString("N0")</td>
                            <td>
                                <span class="badge @(product.IsActive ? "bg-success" : "bg-secondary")">
                                    @(product.IsActive ? "Yes" : "No")
                                </span>
                            </td>
                            <td>
                                <span class="badge @(product.Onsale ? "bg-warning text-dark" : "bg-secondary")">
                                    @(product.Onsale ? "Yes" : "No")
                                </span>
                            </td>
                            <td>@product.Employee?.FullName</td>
                            <td>
                                @product.Barcode
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center py-5 text-muted">Chưa có dữ liệu sản phẩm.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>