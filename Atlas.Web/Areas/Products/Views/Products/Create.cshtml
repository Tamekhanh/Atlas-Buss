@model ProductModelView

@{
    ViewData["Title"] = "Create Product";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Create Product</h1>
            <p class="text-muted mb-0">Form tạo mới sản phẩm với đầy đủ các trường thông tin.</p>
        </div>
        <a asp-area="Products" asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <form asp-area="Products" asp-controller="Product" asp-action="Create" method="post" novalidate>
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input asp-for="EmployeeId" type="hidden" />

                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label asp-for="ProductName" class="form-label fw-semibold"></label>
                        <input asp-for="ProductName" class="form-control" />
                        <span asp-validation-for="ProductName" class="text-danger"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="ProductCode" class="form-label fw-semibold"></label>
                        <input asp-for="ProductCode" class="form-control" />
                        <span asp-validation-for="ProductCode" class="text-danger"></span>
                    </div>

                    <div class="col-12 col-md-6">
                        <label asp-for="SalePrice" class="form-label fw-semibold"></label>
                        <input asp-for="SalePrice" class="form-control" type="number" step="0.01" min="0.01" />
                        <span asp-validation-for="SalePrice" class="text-danger"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="CostPrice" class="form-label fw-semibold"></label>
                        <input asp-for="CostPrice" class="form-control" type="number" step="0.01" min="0.01" />
                        <span asp-validation-for="CostPrice" class="text-danger"></span>
                    </div>

                    <div class="col-12 col-md-6">
                        <label asp-for="ImageUrl" class="form-label fw-semibold"></label>
                        <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                        <span asp-validation-for="ImageUrl" class="text-danger"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="Barcode" class="form-label fw-semibold"></label>
                        <input asp-for="Barcode" class="form-control" />
                        <span asp-validation-for="Barcode" class="text-danger"></span>
                    </div>

                    <div class="col-12 col-md-4">
                        <div class="form-check mt-4 pt-2">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label fw-semibold"></label>
                        </div>
                    </div>
                    <div class="col-12 col-md-4">
                        <div class="form-check mt-4 pt-2">
                            <input asp-for="Onsale" class="form-check-input" />
                            <label asp-for="Onsale" class="form-check-label fw-semibold"></label>
                        </div>
                    </div>

                    <div class="col-12">
                        <label asp-for="ProductDescription" class="form-label fw-semibold"></label>
                        <textarea asp-for="ProductDescription" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="ProductDescription" class="text-danger"></span>
                    </div>

                    <div class="col-12 col-md-4">
                        <label asp-for="Weight" class="form-label fw-semibold"></label>
                        <input asp-for="Weight" class="form-control" type="number" step="0.01" min="0" />
                        <span asp-validation-for="Weight" class="text-danger"></span>
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="WarrantyPeriod" class="form-label fw-semibold"></label>
                        <input asp-for="WarrantyPeriod" class="form-control" type="number" min="0" />
                        <span asp-validation-for="WarrantyPeriod" class="text-danger"></span>
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="Manufacturer" class="form-label fw-semibold"></label>
                        <input asp-for="Manufacturer" class="form-control" />
                        <span asp-validation-for="Manufacturer" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Dimensions" class="form-label fw-semibold"></label>
                        <input asp-for="Dimensions" class="form-control" placeholder="L x W x H" />
                        <span asp-validation-for="Dimensions" class="text-danger"></span>
                    </div>

                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Create</button>
                    <a asp-area="Products" asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>